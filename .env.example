# =====================
# ENVIRONMENT SWITCH (dev / prod)
# =====================
# Spring profile cac service se load tu config-server (<service>-<profile>.yml)
#   dev  -> config tro toi localhost (chay business service ngoai IDE)
#   prod -> config tro toi hostname trong docker network
SPRING_PROFILES_ACTIVE=prod

# Docker Compose profile: service nao se duoc khoi dong
#   de trong  -> chi chay infra (mysql, rabbitmq, config-server, discovery-service) cho mode dev
#   prod      -> chay toan bo stack trong docker
COMPOSE_PROFILES=prod

# =====================
# SECRETS
# =====================
# Stripe (required for order-service payment)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Gmail App Password (required for notification-service)
MAIL_PASSWORD=your_gmail_app_password_here
